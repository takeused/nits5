# 로컬 프록시 전용. 이 파일을 .env로 복사한 뒤 실제 값을 입력하세요.
SC_CLIENT_ID=
SC_API_KEY=
SC_MAC_ADDR=
NTIS_API_KEY=

# ── AI (둘 중 하나만 있어도 동작. 둘 다 있으면 Cerebras 우선, 실패 시 Gemini로 자동 전환) ──
CEREBRAS_API_KEY=
# Google AI Studio에서 발급: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# 사용할 Gemini 모델명. 비워두면 gemini-3.1-flash-lite 사용.
# 모델명이 바뀌거나 404가 나면 여기서 교체하세요 (예: gemini-2.5-flash-lite).
GEMINI_MODEL=
